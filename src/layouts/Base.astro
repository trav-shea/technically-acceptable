---
// Base — the page shell every route wraps.
//
// Does: emits the full <html> document — <head> meta, the global stylesheet,
// the top StatusBar, the four corner registration ticks, the page body via
// <slot/>, the footer, and the minimal client script (clock + code-copy +
// mobile-TOC toggle).
// Does NOT: know page content — pages fill <slot/>.
//
// The footer's right-hand meta varies by tier (Home shows an entry total;
// Section/Entry show breadcrumb-style links), so it's a named slot. Its
// DEFAULT is the derived Home meta: the entry total is counted from content,
// never typed.
import { site } from '../config/site';
import StatusBar, { type StatusSegment } from '../components/StatusBar.astro';
import { getVisibleEntries } from '../lib/content';
import '../styles/technically-acceptable.css';

interface Props {
  /** Page <title>. Required — no silent default. */
  title: string;
  /** Value for <body data-screen-label> (mirrors the prototype). */
  screenLabel?: string;
  /** Per-tier status strip; omitted = the Home default in StatusBar. */
  statusbar?: { brandHref?: string; segments?: StatusSegment[] };
}

const { title, screenLabel, statusbar } = Astro.props;

// Derived site-wide footer total (visible entries in this build).
const totalEntries = (await getVisibleEntries()).length;
const entriesWord = totalEntries === 1 ? 'ENTRY' : 'ENTRIES';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body data-screen-label={screenLabel}>
    <StatusBar brandHref={statusbar?.brandHref} segments={statusbar?.segments} />

    <span class="tick tl"></span><span class="tick tr"></span>
    <span class="tick bl"></span><span class="tick br"></span>

    <slot />

    <footer class="footbar">
      <div class="frame">
        <span class="handle">&mdash; <span class="em">{site.footerHandle}</span></span>
        <div class="foot-meta">
          <slot name="foot-meta">
            <span>{totalEntries} {entriesWord}</span>
            <span>NO TRACKERS</span>
            <span>BUILT TO LAST</span>
          </slot>
        </div>
      </div>
    </footer>

    {/* Minimal interaction layer, ported verbatim. is:inline keeps it a static
        asset (no Astro bundling) so it matches the prototype byte-for-byte. */}
    <script is:inline src="/technically-acceptable.js"></script>
  </body>
</html>
