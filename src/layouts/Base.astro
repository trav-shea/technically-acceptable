---
// Base — the page shell every route wraps.
//
// Does: emits the full <html> document — <head> meta, the global stylesheet,
// the top StatusBar, the four corner registration ticks, the page body via
// <slot/>, the footer, and the minimal client script (clock + code-copy +
// mobile-TOC toggle).
// Does NOT: know anything about page content — pages fill the <slot/>.
// Fails loudly: `title` is a required prop with no default, so a page that
// forgets to set a <title> won't silently ship a blank one — the build errors.
import { site } from '../config/site';
import StatusBar from '../components/StatusBar.astro';
import '../styles/field-notes.css';

interface Props {
  /** Page <title>. Required — no silent default. */
  title: string;
  /** Value for <body data-screen-label> (mirrors the prototype). */
  screenLabel?: string;
}

const { title, screenLabel } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body data-screen-label={screenLabel}>
    <StatusBar />

    <span class="tick tl"></span><span class="tick tr"></span>
    <span class="tick bl"></span><span class="tick br"></span>

    <slot />

    <footer class="footbar">
      <div class="frame">
        <span class="handle">&mdash; <span class="em">{site.footerHandle}</span></span>
        <div class="foot-meta">
          {/* Phase 0 literals — these three become derived from content in Phase 1
              (total entry count) or stay static truths (NO TRACKERS / BUILT TO LAST).
              The prototype's "21 ENTRIES" is internally inconsistent with its own
              card counts (6+4+3=13); the real value gets derived in Phase 1. */}
          <span>21 ENTRIES</span>
          <span>NO TRACKERS</span>
          <span>BUILT TO LAST</span>
        </div>
      </div>
    </footer>

    {/* Minimal interaction layer, ported verbatim. is:inline keeps it a static
        asset (no Astro bundling) so it matches the prototype byte-for-byte. */}
    <script is:inline src="/field-notes.js"></script>
  </body>
</html>
