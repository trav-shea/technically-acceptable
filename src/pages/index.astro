---
// Home — the index of all subjects.
//
// Phase 0: a faithful static reproduction of the prototype's Home.html, with
// the identity strings swapped to the new brand (site.ts). The derived values
// flagged below (divider count, per-card lesson tags, REV date) are Phase 0
// literals — Phase 1 replaces them with counts computed from content
// collections at build time. No new layout or design has been introduced.
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
---

<Base title={`${site.name} — Index`} screenLabel="HOME">
  <main class="frame">
    <!-- masthead -->
    <header class="masthead">
      <div class="designation">
        <span class="wordmark">{site.wordmarkParts[0]}<span class="em">·</span>{site.wordmarkParts[1]}</span>
        <span class="meta">
          <span>{site.designationLine}</span>
          {/* Phase 0 literal — REV date becomes max(entry dates) in Phase 1. */}
          <span>REV 2026.06</span>
        </span>
      </div>

      <h1 class="lede">Replicable procedures for building and securing <span class="em">real systems</span>.</h1>
      <p class="subhead">{site.subhead}</p>
    </header>

    <!-- subjects -->
    <div class="divider">
      <span class="label">Subjects</span>
      {/* Phase 0 literal — "total / active" gets derived from the sections
          collection in Phase 1. */}
      <span class="count mono">06 / 04 ACTIVE</span>
    </div>

    <section class="grid">
      <!-- Phase 0: card markup reproduced from the prototype. In Phase 1 these
           render from the `sections` collection and the "N Lessons" tags become
           derived entry counts. The Home Lab card links to its future route
           (/home-lab/), which is built in Phase 1. -->
      <a class="card" href="/home-lab/">
        <div class="card-index"><span>01</span><span class="card-go">&rarr;</span></div>
        <div class="card-name">Home Lab</div>
        <p class="card-desc">Network design, segmentation, and self-hosted services on real hardware.</p>
        <div class="card-foot">
          <span class="tag active">6 Lessons</span>
          <span class="label">NET / INFRA</span>
        </div>
      </a>

      <div class="card">
        <div class="card-index"><span>02</span><span class="card-go">&rarr;</span></div>
        <div class="card-name">Python</div>
        <p class="card-desc">Automation, tooling, and data work &mdash; from one-off scripts to packaged CLIs.</p>
        <div class="card-foot">
          <span class="tag progress">In Progress</span>
          <span class="label">SOFTWARE</span>
        </div>
      </div>

      <div class="card">
        <div class="card-index"><span>03</span><span class="card-go">&rarr;</span></div>
        <div class="card-name">CMMC</div>
        <p class="card-desc">Cybersecurity Maturity Model Certification: controls, scoping, and evidence.</p>
        <div class="card-foot">
          <span class="tag active">4 Lessons</span>
          <span class="label">COMPLIANCE</span>
        </div>
      </div>

      <div class="card soon">
        <div class="card-index"><span>04</span></div>
        <div class="card-name">OSINT</div>
        <p class="card-desc">Open-source collection and analysis tradecraft, done responsibly.</p>
        <div class="card-foot">
          <span class="tag">Coming Soon</span>
          <span class="label">RECON</span>
        </div>
      </div>

      <div class="card soon">
        <div class="card-index"><span>05</span></div>
        <div class="card-name">AI / ML</div>
        <p class="card-desc">Practical models: training, evaluation, and deployment without the hype.</p>
        <div class="card-foot">
          <span class="tag">Coming Soon</span>
          <span class="label">MODELS</span>
        </div>
      </div>

      <div class="card">
        <div class="card-index"><span>06</span><span class="card-go">&rarr;</span></div>
        <div class="card-name">Math&nbsp;(for fun)</div>
        <p class="card-desc">Linear algebra, probability, and number theory worked from scratch.</p>
        <div class="card-foot">
          <span class="tag active">3 Lessons</span>
          <span class="label">THEORY</span>
        </div>
      </div>
    </section>
  </main>
</Base>
