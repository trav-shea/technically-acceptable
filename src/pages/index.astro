---
// Home: the index of all subjects, rendered from the sections collection.
//
// Every number here is DERIVED at build time, never typed:
//   - per-card lesson count    = visible entries in that section
//   - divider "NN / MM ACTIVE" = total sections / non-"soon" sections
//   - masthead REV             = newest entry date across the site
// Adding a section .yaml or an entry .mdx changes these with no edits here.
import Base from '../layouts/Base.astro';
import Card from '../components/Card.astro';
import { site } from '../config/site';
import { getSections, getVisibleEntries, entriesInSection, pad2, revString } from '../lib/content';

const sections = await getSections();
const entries = await getVisibleEntries();

const totalSections = sections.length;
// "Active" in the divider means live (not coming-soon), reproduces the
// prototype's "4 of 6" (active + in-progress, excluding the two "soon" cards).
const activeSections = sections.filter((s) => s.data.status !== 'soon').length;
const rev = revString(entries);

const cards = sections.map((section, i) => {
  const count = entriesInSection(entries, section.id).length;
  const isSoon = section.data.status === 'soon';
  return {
    indexLabel: pad2(i + 1),
    name: section.data.name,
    summary: section.data.summary,
    label: section.data.label,
    isSoon,
    // Soon cards aren't links. No section page is generated for them.
    href: isSoon ? null : `/${section.id}/`,
    tagText:
      section.data.status === 'active'
        ? `${count} Lesson${count === 1 ? '' : 's'}`
        : section.data.status === 'in-progress'
          ? 'In Progress'
          : 'Coming Soon',
    tagClass:
      section.data.status === 'active'
        ? 'tag active'
        : section.data.status === 'in-progress'
          ? 'tag progress'
          : 'tag',
  };
});
---

<Base title={`${site.name}: Index`} screenLabel="HOME">
  <main class="frame">
    <header class="masthead">
      <div class="designation">
        <span class="wordmark">{site.wordmarkParts[0]}<span class="em">·</span>{site.wordmarkParts[1]}</span>
        <span class="meta">
          <span>{site.designationLine}</span>
          <span>REV {rev ?? 'TBD'}</span>
        </span>
      </div>

      <h1 class="lede">Tech projects and guides, built in the open and <span class="em">made to replicate</span>.</h1>
      <p class="subhead">{site.subhead}</p>
    </header>

    <div class="divider">
      <span class="label">Subjects</span>
      <span class="count mono">{pad2(totalSections)} / {pad2(activeSections)} ACTIVE</span>
    </div>

    <section class="grid">
      {cards.map((card) => <Card {...card} />)}
    </section>
  </main>
</Base>
