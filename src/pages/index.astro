---
// Home: the subjects index, split into two job-based groups (Field Guides,
// then Build). Sections carry a `group` field in their yaml.
//
// Derived at build time, never typed:
//   - per-card count = visible entries in that section
//   - masthead REV   = newest entry date across the site
// Adding a section .yaml or an entry .mdx updates the grid with no edits here.
import Base from '../layouts/Base.astro';
import Card from '../components/Card.astro';
import Subscribe from '../components/Subscribe.astro';
import { site } from '../config/site';
import { getSections, getVisibleEntries, entriesInSection, pad2, revString, type Section } from '../lib/content';

const sections = await getSections();
const entries = await getVisibleEntries();
const rev = revString(entries);

function toCard(section: Section, indexLabel: string) {
  const count = entriesInSection(entries, section.id).length;
  const isSoon = section.data.status === 'soon';
  return {
    indexLabel,
    name: section.data.name,
    summary: section.data.summary,
    label: section.data.label,
    isSoon,
    href: isSoon ? null : `/${section.id}/`,
    tagText:
      section.data.status === 'active'
        ? `${count} Lesson${count === 1 ? '' : 's'}`
        : section.data.status === 'in-progress'
          ? 'In Progress'
          : 'Coming Soon',
    tagClass:
      section.data.status === 'active'
        ? 'tag active'
        : section.data.status === 'in-progress'
          ? 'tag progress'
          : 'tag',
  };
}

// Field Guides renders first, then Build. Within each group, sections keep
// their `order`. Card index labels restart at 01 per group.
const groups = [
  { id: 'field-guides', title: 'Field Guides' },
  { id: 'build', title: 'Build' },
].map((g) => ({
  ...g,
  cards: sections.filter((s) => s.data.group === g.id).map((s, i) => toCard(s, pad2(i + 1))),
}));
---

<Base title={`${site.name}: Index`} screenLabel="HOME">
  <main class="frame">
    <header class="masthead">
      <div class="designation">
        <span class="wordmark">{site.wordmarkParts[0]}<span class="em">·</span>{site.wordmarkParts[1]}</span>
        <span class="meta">
          <span>{site.designationLine}</span>
          <span>REV {rev ?? 'TBD'}</span>
        </span>
      </div>

      <h1 class="lede">Practical cybersecurity and AI. <span class="em">Built, broken, documented.</span></h1>
      <p class="subhead">{site.subhead}</p>
      <p><a class="tag active" href="/home-lab/">See how I run my stack &rarr;</a></p>
    </header>

    {
      groups.map((group) => (
        <Fragment>
          <div class="divider" id={group.id}>
            <span class="label">{group.title}</span>
            <span class="count mono">{pad2(group.cards.length)}</span>
          </div>
          <section class="grid">
            {group.cards.map((card) => (
              <Card {...card} />
            ))}
          </section>
        </Fragment>
      ))
    }

    <section class="home-brief">
      <Subscribe
        heading="The Brief"
        valueProp="A weekly, plain-English read on CMMC and defense compliance. Launching soon."
      />
    </section>
  </main>
</Base>

<style>
  /* Spacing only for the homepage subscribe module. No design tokens added. */
  .home-brief {
    margin-top: clamp(40px, 6vw, 72px);
  }
</style>
